APP_ENV=development
APP_NAME=ModelGate
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
LOG_PARTIAL_SECRETS=false
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=modelgate
POSTGRES_USER=modelgate
POSTGRES_PASSWORD=modelgate_password
DATABASE_URL=postgresql+psycopg://modelgate:modelgate_password@localhost:5432/modelgate

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

HOST_WEB_PORT=3000
HOST_API_PORT=8000
HOST_POSTGRES_PORT=5432
HOST_REDIS_PORT=6379
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

MIMO_API_KEY=
MINIMAX_API_KEY=
VOLCENGINE_API_KEY=
MOONSHOT_API_KEY=
ZHIPU_API_KEY=
MODELGATE_SECRET_KEY=

STORAGE_DRIVER=local
STORAGE_ROOT=./storage
UPLOADS_DIR=./storage/uploads
OUTPUTS_DIR=./storage/outputs
PREVIEWS_DIR=./storage/previews

MAX_IMAGE_MB=20
MAX_VIDEO_MB=500
MAX_AUDIO_MB=100
MAX_DOCUMENT_MB=100
MAX_CODE_MB=5
MAX_TOTAL_UPLOAD_MB=1024
MAX_FILENAME_LENGTH=255

ENABLE_STREAMING=false
ENABLE_SEEDANCE=false
ENABLE_AUTH=false
ENABLE_OBJECT_STORAGE=false

# Development shortcut: run generation submissions inline in a daemon
# thread instead of dispatching to a Celery worker. Useful for local
# exploration and one-shot smoke tests; not for production.
DISABLE_CELERY=false
